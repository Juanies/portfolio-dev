---
    const {title, date, description, place} = Astro.props
---
<li class="ms-4 pb-6 flex flex-col gap-y-1">
    <div class="absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -start-1.5 border border-white"></div>
    <div>
        <h3 class="text-xl font-bold text-yellow-300">{title}</h3>
        <p class="text-1xl opacity-70 font-bold text-yellow-300">{place}</p>
    </div>
    <div>
        <time class="mb-1 text-sm font-normal leading-none text-gray-400 dark:text-gray-500">{date}</time>
        <p class="text-base font-normal w-[700px] text-gray-500 dark:text-gray-400">{description}</p>
    </div>
</li>