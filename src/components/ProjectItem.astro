---
    const {title, description, img, url, stack} = Astro.props
---

<article class="w-[740px] mt-5 flex pb-32 items-center justify-end relative">
    <a href={url} class="absolute top-0">
        <img class="w-[50%] object-contain -z-10" src={img} alt={title}>
    </a>

        <div class="flex w-[60%] z-0  flex-col">
            <div class="flex gap-x-2 justify-end pb-3 flex-wrap">
                {
                    stack.map((e: string) => (
                        <span class="flex p-2 rounded bg-[#18191d]">{e}</span>
                    ))
                }
            </div>
            <div class="bg-[#18191d] pointer-events-none flex flex-col p-4">
                <h2 class="text-2xl font-bold bg-black/2">{title}</h2>
                <p class="py-2 text-1xl opacity-80 font-[400]">{description}</p>
            </div>
        </div>
    </div>
</article>